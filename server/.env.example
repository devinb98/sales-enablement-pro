# Copy to `server/.env` and fill in. Never commit the real .env.

# Flask ------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-random-64-char-hex-string
FLASK_ENV=development

# Database ---------------------------------------------------------------
# Local dev defaults to SQLite if unset. Render injects a postgres:// URL,
# which config.py rewrites to postgresql:// for SQLAlchemy 2.x.
DATABASE_URL=sqlite:///dev.db

# CORS -------------------------------------------------------------------
# The React origin allowed to send credentialed requests.
FRONTEND_ORIGIN=http://localhost:5173

# AI: Google Gemini (generation + embeddings) ----------------------------
# Free tier key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-key

# Deck export: Presenton hosted API --------------------------------------
# Key from https://presenton.ai/api-key — credit-metered at ~1 credit/slide.
# PRESENTON_LIVE is off by default so development and tests run against a
# cached .pptx fixture instead of spending credits. Set to 1 to call for real.
PRESENTON_API_KEY=sk-presenton-your-key-here
PRESENTON_BASE_URL=https://api.presenton.ai
PRESENTON_LIVE=0

# Retrieval tuning -------------------------------------------------------
CHROMA_DIR=/tmp/chroma
RETRIEVAL_TOP_K=8
RETRIEVAL_MIN_SCORE=0.25
